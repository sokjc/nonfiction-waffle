# Strategy Agent — Environment Configuration
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env:  cp .env.example .env
#
# The defaults work out of the box with a local LLM server (vLLM, Ollama,
# LM Studio, or text-generation-inference) running on localhost:8000.
# No environment variables are strictly REQUIRED — every setting has a default.
# ─────────────────────────────────────────────────────────────────────────────

# ── Primary LLM Endpoint (RECOMMENDED to configure) ──────────────────────────
# Any OpenAI-compatible /v1/chat/completions server.
#
# Examples:
#   Ollama:   http://localhost:11434/v1
#   vLLM:     http://localhost:8000/v1
#   LM Studio: http://localhost:1234/v1
#
LLM_BASE_URL=http://localhost:8000/v1        # (string, URL)
LLM_API_KEY=not-needed                       # (string) Set "not-needed" for local servers
LLM_MODEL=gemma4-31b                         # (string) Model name your server recognizes

# ── Evaluation LLM (OPTIONAL — falls back to primary LLM) ────────────────────
# Use a heavier model for scoring drafts.  If unset, the primary LLM handles
# both writing and evaluation.
#
# EVAL_BASE_URL=http://localhost:8001/v1
# EVAL_API_KEY=not-needed
# EVAL_MODEL=nemotron-120b

# ── Embeddings (OPTIONAL — defaults to local sentence-transformers) ───────────
# By default, embeddings run locally using the all-MiniLM-L6-v2 model (~90 MB,
# downloaded automatically on first run).  No external API needed.
#
EMBEDDING_MODEL=all-MiniLM-L6-v2             # (string) HuggingFace model name
#
# To use a remote embedding endpoint instead:
# EMBEDDING_BASE_URL=http://localhost:8002/v1
# EMBEDDING_API_KEY=not-needed
# EMBEDDING_MODEL=text-embedding-3-small

# ── Vector Store (OPTIONAL) ──────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./data/vectorstore        # (path) Where ChromaDB stores embeddings
CHROMA_COLLECTION=strategy_corpus            # (string) Collection name

# ── Paths (OPTIONAL) ─────────────────────────────────────────────────────────
CORPUS_DIR=./corpus                          # (path) Directory of strategy documents to ingest
OUTPUT_DIR=./output                          # (path) Where generated documents are saved

# ── Knowledge Graph (OPTIONAL) ───────────────────────────────────────────────
KNOWLEDGE_GRAPH_PATH=./data/knowledge_graph.gml  # (path) NetworkX graph persistence file

# ── Chat & Session Persistence (OPTIONAL) ─────────────────────────────────────
SESSION_DB_PATH=./data/sessions.db           # (path) SQLite database for chat session history

# ── Agent Tuning (OPTIONAL) ──────────────────────────────────────────────────
MAX_REWRITE_LOOPS=3                          # (int) Max evaluate→rewrite iterations before accepting
CHUNK_SIZE=1500                              # (int, characters) Target size for document chunks
CHUNK_OVERLAP=300                            # (int, characters) Overlap between adjacent chunks
