# ── Model Endpoint Configuration ──────────────────────────────────────────────
# OpenAI-compatible base URL (e.g. vLLM, Ollama, LM Studio, text-generation-inference)
LLM_BASE_URL=http://localhost:8000/v1
LLM_API_KEY=not-needed
LLM_MODEL=gemma4-31b

# Secondary / heavier model for evaluation passes (optional, falls back to LLM_MODEL)
EVAL_MODEL=nemotron-120b
EVAL_BASE_URL=http://localhost:8001/v1
EVAL_API_KEY=not-needed

# ── Embedding Configuration ───────────────────────────────────────────────────
# Local sentence-transformers model (runs on CPU/GPU, no external API needed)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Or use an OpenAI-compatible embedding endpoint:
# EMBEDDING_BASE_URL=http://localhost:8002/v1
# EMBEDDING_API_KEY=not-needed
# EMBEDDING_MODEL=text-embedding-3-small

# ── Vector Store ──────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./data/vectorstore
CHROMA_COLLECTION=strategy_corpus

# ── Corpus & Output ──────────────────────────────────────────────────────────
CORPUS_DIR=./corpus
OUTPUT_DIR=./output

# ── Agent Tuning ──────────────────────────────────────────────────────────────
# Max rewrite iterations before the evaluator accepts the draft
MAX_REWRITE_LOOPS=3
# Chunk size / overlap for document ingestion
CHUNK_SIZE=1500
CHUNK_OVERLAP=300
