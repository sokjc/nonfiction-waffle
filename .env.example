# Strategy Agent — Environment Configuration
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env:  cp .env.example .env
#
# The defaults work out of the box with a local LLM server (vLLM, Ollama,
# LM Studio, or text-generation-inference) running on localhost:8000.
# No environment variables are strictly REQUIRED — every setting has a default.
#
# All LLMs + embeddings share a single OpenAI-compatible endpoint.  The three
# model roles are distinguished only by model name:
#   Writer:    Prose generation and rewriting (default: gpt-oss)
#   Agent:     Research, chat, tool-calling (default: gemma4-31b)
#   Evaluator: Narrative scoring (default: nemotron-120b)
# ─────────────────────────────────────────────────────────────────────────────

# ── Shared endpoint (RECOMMENDED — auth for all models + embeddings) ─────────
# Any OpenAI-compatible endpoint.
#
# Examples:
#   Ollama:    http://localhost:11434/v1
#   vLLM:      http://localhost:8000/v1
#   LM Studio: http://localhost:1234/v1
#
LLM_BASE_URL=http://localhost:8000/v1        # (string, URL)
LLM_API_KEY=not-needed                       # (string) Set "not-needed" for local servers

# ── Writer LLM (prose generation) ────────────────────────────────────────────
# Optimized for fluent, stylish output.  gpt-oss is a strong default.
WRITER_MODEL=gpt-oss                         # (string) Model name your server recognizes
# WRITER_TEMPERATURE=0.7                     # (float)
# WRITER_MAX_TOKENS=4096                     # (int)

# ── Agent LLM (research, chat, tool-calling) ─────────────────────────────────
# Needs strong instruction-following and tool-use.  gemma4-31b is a strong default.
AGENT_MODEL=gemma4-31b                       # (string)
# AGENT_TEMPERATURE=0.4                      # (float)
# AGENT_MAX_TOKENS=4096                      # (int)

# ── Evaluator LLM (narrative scoring) ────────────────────────────────────────
# Benefits from a heavier model for better judgment.  Using a DIFFERENT model
# than the writer avoids the "grading your own homework" problem.
EVAL_MODEL=nemotron-120b                     # (string)
# EVAL_TEMPERATURE=0.3                       # (float)
# EVAL_MAX_TOKENS=4096                       # (int)

# ── Embeddings (shares LLM_BASE_URL by default) ──────────────────────────────
EMBEDDING_MODEL=nomic-ai/nomic-embed-text-v1.5  # (string) Model name your server recognizes
#
# For local embeddings via sentence-transformers (requires PyTorch — not
# supported on Intel Mac), install the extra and flip the flag:
#   uv pip install -e ".[local]"
#   EMBEDDING_LOCAL=true
# EMBEDDING_LOCAL=false                      # (bool)

# ── LlamaIndex Vector Store (OPTIONAL) ───────────────────────────────────────
INDEX_PERSIST_DIR=./data/index               # (path) Where LlamaIndex persists the index

# ── Paths (OPTIONAL) ─────────────────────────────────────────────────────────
CORPUS_DIR=./corpus                          # (path) Directory of strategy documents to ingest
OUTPUT_DIR=./output                          # (path) Where generated documents are saved

# ── Knowledge Graph (OPTIONAL) ───────────────────────────────────────────────
KNOWLEDGE_GRAPH_PATH=./data/knowledge_graph.gml  # (path) NetworkX graph file

# ── Chat & Session Persistence (OPTIONAL) ─────────────────────────────────────
SESSION_DB_PATH=./data/sessions.db           # (path) SQLite DB for chat session history

# ── Agent Tuning (OPTIONAL) ──────────────────────────────────────────────────
MAX_REWRITE_LOOPS=3                          # (int) Max evaluate-rewrite iterations
CHUNK_SIZE=1500                              # (int, characters) Target chunk size
CHUNK_OVERLAP=300                            # (int, characters) Overlap between chunks
# CONTEXT_STUFFING_DOCS=5                    # (int) Full source docs to include in LLM context
